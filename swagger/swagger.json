  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT 액세스 토큰. 알고리즘: HS-512. `/api/auth/login` 또는 `/api/auth/register`에서 발급. `Authorization: Bearer <token>` 형식으로 전달."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "description": "사용자 정보. `password_hash`는 응답에 포함되지 않습니다.",
        "properties": {
          "id": {
            "type": "integer",
            "description": "사용자 고유 식별자 (자동 증가)",
            "example": 1
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 255,
            "description": "사용자 이메일 (시스템 전체 고유)",
            "example": "user@example.com"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "계정 생성 일시 (ISO 8601, UTC)",
            "example": "2026-04-28T00:00:00.000Z"
          }
        },
        "required": ["id", "email", "createdAt"]
      },
      "Category": {
        "type": "object",
        "description": "카테고리 정보",
        "properties": {
          "id": {
            "type": "integer",
            "description": "카테고리 고유 식별자 (자동 증가)",
            "example": 1
          },
          "userId": {
            "type": "integer",
            "description": "소유 사용자 ID",
            "example": 1
          },
          "name": {
            "type": "string",
            "maxLength": 20,
            "description": "카테고리 이름 (동일 사용자 내 중복 불가, 최대 20자)",
            "example": "업무"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "카테고리 생성 일시 (ISO 8601, UTC)",
            "example": "2026-04-28T00:00:00.000Z"
          }
        },
        "required": ["id", "userId", "name", "createdAt"]
      },
      "Todo": {
        "type": "object",
        "description": "할일 정보. `status` 필드는 서버에서 동적으로 계산되어 응답에 포함됩니다.",
        "properties": {
          "id": {
            "type": "integer",
            "description": "할일 고유 식별자 (자동 증가)",
            "example": 1
          },
          "userId": {
            "type": "integer",
            "description": "소유 사용자 ID",
            "example": 1
          },
          "categoryId": {
            "type": "integer",
            "nullable": true,
            "description": "소속 카테고리 ID. null이면 미분류",
            "example": 1
          },
          "title": {
            "type": "string",
            "maxLength": 100,
            "description": "할일 제목 (필수, 최대 100자)",
            "example": "API 설계 완료하기"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "nullable": true,
            "description": "할일 설명 (선택, 최대 500자)",
            "example": "OpenAPI 3.0 스펙 작성"
          },
          "dueDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "종료 목표 일시 (선택, ISO 8601, UTC). null이면 기한 초과 판별 대상에서 제외",
            "example": "2026-04-30T18:00:00.000Z"
          },
          "isCompleted": {
            "type": "boolean",
            "description": "완료 여부 (기본값: false)",
            "example": false
          },
          "status": {
            "$ref": "#/components/schemas/TodoStatus"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "할일 생성 일시 (ISO 8601, UTC)",
            "example": "2026-04-28T00:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "할일 최종 수정 일시 (ISO 8601, UTC). 수정 시 자동 갱신",
            "example": "2026-04-28T00:00:00.000Z"
          }
        },
        "required": ["id", "userId", "categoryId", "title", "description", "dueDate", "isCompleted", "status", "createdAt", "updatedAt"]
      },
      "TodoStatus": {
        "type": "string",
        "enum": ["pending", "completed", "overdue"],
        "description": "할일 상태 (동적 계산).\n- `pending`: 미완료 (`is_completed=false`, `due_date IS NULL` 또는 `due_date >= NOW()`)\n- `completed`: 완료 (`is_completed=true`)\n- `overdue`: 기한 초과 (`is_completed=false`, `due_date < NOW()`)",
        "example": "pending"
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 255,
            "description": "이메일 주소 (시스템 전체 고유)",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "description": "비밀번호 (8자 이상, 영문·숫자 혼합 필수)",
            "example": "password123"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "이메일 주소",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "비밀번호",
            "example": "password123"
          }
        }
      },
      "CategoryCreateRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20,
            "description": "카테고리 이름 (필수, 최대 20자, 동일 사용자 내 중복 불가)",
            "example": "업무"
          }
        }
      },
      "TodoCreateRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "할일 제목 (필수, 최대 100자)",
            "example": "API 설계 완료하기"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "nullable": true,
            "description": "할일 설명 (선택, 최대 500자)",
            "example": "OpenAPI 3.0 스펙 작성"
          },
          "categoryId": {
            "type": "integer",
            "nullable": true,
            "description": "소속 카테고리 ID (선택, 본인 소유 카테고리만 허용). null이면 미분류",
            "example": 1
          },
          "dueDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "종료 목표 일시 (선택, ISO 8601, UTC)",
            "example": "2026-04-30T18:00:00.000Z"
          }
        }
      },
      "TodoUpdateRequest": {
        "type": "object",
        "description": "할일 수정 요청. 포함된 필드만 업데이트됩니다. 최소 하나의 필드가 필요합니다.",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "할일 제목 (최대 100자)",
            "example": "API 설계 및 문서화 완료하기"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "nullable": true,
            "description": "할일 설명 (최대 500자). null 전달 시 설명 제거",
            "example": "OpenAPI 3.0 스펙 작성 및 Swagger UI 연동"
          },
          "categoryId": {
            "type": "integer",
            "nullable": true,
            "description": "소속 카테고리 ID. null 전달 시 미분류로 변경",
            "example": 1
          },
          "dueDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "종료 목표 일시 (ISO 8601, UTC). null 전달 시 기한 제거",
            "example": "2026-04-30T20:00:00.000Z"
          },
          "isCompleted": {
            "type": "boolean",
            "description": "완료 여부",
            "example": true
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "description": "API 성공 응답 공통 포맷",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [true],
            "description": "요청 성공 여부 (항상 true)",
            "example": true
          },
          "data": {
            "description": "응답 데이터. 엔드포인트마다 구조가 다릅니다.",
            "nullable": true
          }
        },
        "required": ["success", "data"]
      },
      "ErrorResponse": {
        "type": "object",
        "description": "API 오류 응답 공통 포맷",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [false],
            "description": "요청 성공 여부 (항상 false)",
            "example": false
          },
          "message": {
            "type": "string",
            "description": "사람이 읽을 수 있는 오류 메시지",
            "example": "요청을 처리하는 중 오류가 발생했습니다."
          }
        },
        "required": ["success", "message"]
      }
    },
    "parameters": {
      "TodoId": {
        "name": "id",
        "in": "path",
        "description": "할일 고유 식별자",
        "required": true,
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "example": 1
      },
      "CategoryId": {
        "name": "id",
        "in": "path",
        "description": "카테고리 고유 식별자",
        "required": true,
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "example": 1
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "인증 실패. JWT 토큰이 없거나 유효하지 않거나 만료되었습니다.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "message": "인증이 필요합니다. 로그인 후 다시 시도해주세요."
            }
          }
        }
      },
      "Forbidden": {
        "description": "권한 없음. 본인 소유가 아닌 리소스에 접근 시도.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "message": "해당 리소스에 접근할 권한이 없습니다."
            }
          }
        }
      },
      "TodoNotFound": {
        "description": "할일을 찾을 수 없음",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "message": "존재하지 않는 할일입니다."
            }
          }
        }
      },
      "CategoryNotFound": {
        "description": "카테고리를 찾을 수 없음",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "message": "존재하지 않는 카테고리입니다."
            }
          }
        }
      },
      "InternalServerError": {
        "description": "서버 내부 오류",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "message": "서버 내부 오류가 발생했습니다. 잠시 후 다시 시도해주세요."
            }
          }
        }
      }
    }
  }
}
