{
  "openapi": "3.0.3",
  "info": {
    "title": "TodoList API",
    "description": "카테고리 분류와 종료일 기반 상태 구분을 지원하는 개인 할일 관리 애플리케이션의 REST API입니다.\n\n## 인증\n모든 보호된 엔드포인트는 `Authorization: Bearer <token>` 헤더를 요구합니다. 토큰은 `/api/auth/login` 또는 `/api/auth/register`에서 발급받습니다.\n\n## 할일 상태 판별 로직\n상태(status)는 DB에 별도 저장되지 않으며 조회 시점에 동적으로 계산됩니다.\n- `is_completed = true` → `completed`\n- `is_completed = false` AND (`due_date IS NULL` OR `due_date >= NOW()`) → `pending`\n- `is_completed = false` AND `due_date < NOW()` → `overdue`\n\n## 공통 응답 형식\n- 성공: `{ \"success\": true, \"data\": ... }`\n- 오류: `{ \"success\": false, \"message\": \"...\" }`",
    "version": "1.0.0",
    "contact": {
      "name": "soominlee",
      "email": "26sh.digital@gmail.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "로컬 개발 서버"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "사용자 인증 및 계정 관리"
    },
    {
      "name": "Categories",
      "description": "카테고리 관리 (JWT 인증 필요)"
    },
    {
      "name": "Todos",
      "description": "할일 관리 (JWT 인증 필요)"
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "회원가입",
        "description": "이메일과 비밀번호로 신규 계정을 생성합니다. 비밀번호는 8자 이상, 영문과 숫자를 혼합해야 합니다. 이메일은 시스템 전체에서 중복 불가합니다. 성공 시 JWT 토큰을 발급합니다.",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              },
              "example": {
                "email": "user@example.com",
                "password": "password123"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "회원가입 성공. JWT 토큰 및 사용자 정보 반환.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "token": {
                              "type": "string",
                              "description": "JWT 액세스 토큰 (HS-512)"
                            },
                            "user": {
                              "$ref": "#/components/schemas/User"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "token": "eyJhbGciOiJIUzUxMiIsInR5cCI6IkpXVCJ9...",
                    "user": {
                      "id": 1,
                      "email": "user@example.com",
                      "createdAt": "2026-04-28T00:00:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "입력값 유효성 검사 실패 (이메일 형식 오류, 비밀번호 규칙 위반 등)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "message": "비밀번호는 8자 이상이며 영문과 숫자를 혼합해야 합니다."
                }
              }
            }
          },
          "409": {
            "description": "이미 사용 중인 이메일",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "message": "이미 사용 중인 이메일입니다."
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그인",
        "description": "이메일과 비밀번호로 로그인합니다. 성공 시 JWT 토큰을 발급합니다.",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "email": "user@example.com",
                "password": "password123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "로그인 성공. JWT 토큰 및 사용자 정보 반환.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "token": {
                              "type": "string",
                              "description": "JWT 액세스 토큰 (HS-512)"
                            },
                            "user": {
                              "$ref": "#/components/schemas/User"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "token": "eyJhbGciOiJIUzUxMiIsInR5cCI6IkpXVCJ9...",
                    "user": {
                      "id": 1,
                      "email": "user@example.com",
                      "createdAt": "2026-04-28T00:00:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "입력값 누락 (이메일 또는 비밀번호 미입력)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "message": "이메일과 비밀번호를 입력해주세요."
                }
              }
            }
          },
          "401": {
            "description": "이메일 또는 비밀번호 불일치",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "message": "이메일 또는 비밀번호가 올바르지 않습니다."
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "내 정보 조회",
        "description": "JWT 토큰으로 인증된 현재 사용자의 정보를 조회합니다.",
        "operationId": "getMe",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "사용자 정보 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "user": {
                              "$ref": "#/components/schemas/User"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "user": {
                      "id": 1,
                      "email": "user@example.com",
                      "createdAt": "2026-04-28T00:00:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그아웃",
        "description": "현재 세션을 종료합니다. 클라이언트 측에서 토큰을 삭제해야 합니다. 서버는 stateless JWT 방식을 사용하므로 클라이언트 토큰 폐기를 안내합니다.",
        "operationId": "logout",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "로그아웃 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "data": null
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/categories": {
      "get": {
        "tags": ["Categories"],
        "summary": "카테고리 목록 조회",
        "description": "현재 인증된 사용자의 카테고리 목록을 생성일 오름차순으로 반환합니다. 다른 사용자의 카테고리는 조회되지 않습니다.",
        "operationId": "getCategories",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "카테고리 목록 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "categories": {
                              "type": "array",
                              "items": {
                                "$ref": "#/components/schemas/Category"
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "categories": [
                      {
                        "id": 1,
                        "userId": 1,
                        "name": "업무",
                        "createdAt": "2026-04-28T00:00:00.000Z"
                      },
                      {
                        "id": 2,
                        "userId": 1,
                        "name": "개인",
                        "createdAt": "2026-04-28T01:00:00.000Z"
                      }
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "post": {
        "tags": ["Categories"],
        "summary": "카테고리 생성",
        "description": "새 카테고리를 생성합니다. 카테고리 이름은 필수이며 최대 20자입니다. 동일 사용자 내에서 이름이 중복될 수 없습니다.",
        "operationId": "createCategory",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CategoryCreateRequest"
              },
              "example": {
                "name": "업무"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "카테고리 생성 성공",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "category": {
                              "$ref": "#/components/schemas/Category"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "category": {
                      "id": 1,
                      "userId": 1,
                      "name": "업무",
                      "createdAt": "2026-04-28T00:00:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "입력값 유효성 검사 실패 (이름 누락 또는 20자 초과)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "message": "카테고리 이름은 필수이며 최대 20자입니다."
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "409": {
            "description": "동일 사용자 내 카테고리 이름 중복",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "message": "이미 존재하는 카테고리 이름입니다."
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/categories/{id}": {
      "put": {
        "tags": ["Categories"],
        "summary": "카테고리 수정",
        "description": "카테고리 이름을 수정합니다. 본인 소유의 카테고리만 수정 가능합니다. 수정 후 이름이 동일 사용자 내 다른 카테고리와 중복될 수 없습니다.",
        "operationId": "updateCategory",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "$ref": "#/components/parameters/CategoryId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CategoryCreateRequest"
              },
              "example": {
                "name": "개인 프로젝트"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "카테고리 수정 성공",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "category": {
                              "$ref": "#/components/schemas/Category"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "category": {
                      "id": 1,
                      "userId": 1,
                      "name": "개인 프로젝트",
                      "createdAt": "2026-04-28T00:00:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "입력값 유효성 검사 실패 (이름 누락 또는 20자 초과)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "message": "카테고리 이름은 필수이며 최대 20자입니다."
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/CategoryNotFound"
          },
          "409": {
            "description": "동일 사용자 내 카테고리 이름 중복",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "message": "이미 존재하는 카테고리 이름입니다."
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "delete": {
        "tags": ["Categories"],
        "summary": "카테고리 삭제",
        "description": "카테고리를 영구 삭제합니다. 본인 소유의 카테고리만 삭제 가능합니다. 삭제 시 해당 카테고리에 속한 할일의 `categoryId`는 `null`(미분류)로 변경되며, 할일 자체는 삭제되지 않습니다.",
        "operationId": "deleteCategory",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "$ref": "#/components/parameters/CategoryId"
          }
        ],
        "responses": {
          "204": {
            "description": "카테고리 삭제 성공 (응답 본문 없음)"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/CategoryNotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/todos": {
      "get": {
        "tags": ["Todos"],
        "summary": "할일 목록 조회",
        "description": "현재 인증된 사용자의 할일 목록을 조회합니다. `status`와 `categoryId` 쿼리 파라미터로 필터링할 수 있습니다. 상태(status)는 DB에 저장되지 않으며 `is_completed`와 `due_date`를 기반으로 동적 계산됩니다.",
        "operationId": "getTodos",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "할일 상태 필터. 미입력 시 전체 조회.",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/TodoStatus"
            }
          },
          {
            "name": "categoryId",
            "in": "query",
            "description": "카테고리 ID 필터. 미입력 시 전체 조회. `0` 또는 `null`을 전달하면 미분류 할일만 조회할 수 있습니다.",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "할일 목록 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "todos": {
                              "type": "array",
                              "items": {
                                "$ref": "#/components/schemas/Todo"
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "todos": [
                      {
                        "id": 1,
                        "userId": 1,
                        "categoryId": 1,
                        "title": "API 설계 완료하기",
                        "description": "OpenAPI 3.0 스펙 작성",
                        "dueDate": "2026-04-30T18:00:00.000Z",
                        "isCompleted": false,
                        "status": "pending",
                        "createdAt": "2026-04-28T00:00:00.000Z",
                        "updatedAt": "2026-04-28T00:00:00.000Z"
                      }
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "description": "쿼리 파라미터 유효성 검사 실패 (잘못된 status 값 등)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "success": false,
                  "message": "status는 pending, completed, overdue 중 하나여야 합니다."
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "post": {
        "tags": ["Todos"],
        "summary": "할일 생성",
        "description": "새 할일을 생성합니다. 제목은 필수(최대 100자)이며, 설명(최대 500자), 카테고리, 종료일은 선택 사항입니다. 생성 시 완료 여부는 기본값 `false`(미완료)로 설정됩니다.",
        "operationId": "createTodo",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TodoCreateRequest"
              },
